@model IGOB.Models.Requisicion
<!-- CONDICIONES DE PAGO -->
@{ var activar = "";}
@switch (Model.oRequisicones.IdEstatusRequisicion)
{
    case 50:
    case 75:
    case 85:
        if (ViewBag.IdPerfil == 4)
        {
            activar = "disabledClick";
        }
        else
        { activar = ""; }
        break;
    default:
        { activar = "disabledClick"; }
        break;
}
<div id="div_condiciones_pago" class="container-fluid tab-pane fade">
    <div class="row bg-secondary text-white sub_banner">
        <div class="col-12" align="center">
            <strong>VALIDAR CONDICIONES DE PAGO</strong>
        </div>
    </div>
    <br />
    <div id="cargarLoadCondicionesDePgo" class="@(activar) col-12">
        @using (Html.BeginForm(null, null, FormMethod.Post, new { @Class = "data-form", @id = "div_condiciones_pagoForm" }))
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary()
            <input type="hidden" id="IdRequisicionCondicionPago" value="@Model.condicionPago.IdRequisicionCondicionPago" />
            <div class="row">
                <div class="col-sm-4">
                    <div class="form-group">
                        <label>Cantidad</label>
                        <input type="number" id="PlazoPagoCantidad" class="form-control" value="@Model.condicionPago.PlazoPagoCantidad" min="1" required><br>

                    </div>
                </div>
                <div class="col-sm-4">
                    <div class="form-group">
                        <label>Unidad</label>
                        @Html.DropDownList("IdPlazoTiempoPago", ViewBag.lstPlazoTiempoPago as SelectList, "Seleccione Unidad", new { @class = "form-control ", @Required = "", @id = "IdPlazoTiempoPago" })
                    </div>
                </div>
                <div class="col-sm-4">
                    <div class="form-group">
                        <label>Día</label>
                        @Html.DropDownList("IdTipoDiaPago", ViewBag.lstTipoDiaPago as SelectList, "Seleccione opción", new { @class = "form-control ", @Required = "", @id = "IdTipoDiaPago" })
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-sm-4 ml-auto">
                    <div class="form-group">
                        <label>Condición de pago</label>
                        @Html.DropDownList("IdCondicionPago", ViewBag.lstCondicionPago as SelectList, "Seleccione condición", new { @class = "form-control ", @Required = "", @id = "IdCondicionPago" })
                    </div>

                </div>
                <div class="col-sm-4">
                    <div class="form-group">
                        <label>Mapa de localización del lugar de firma de pedido, orden de trabajo o contrato </label>
                        @Html.DropDownList("IdLugarEntregaPago", ViewBag.lstLugarPagoFirma as SelectList, "Seleccione lugar firma", new { @class = "form-control ", @Required = "", @id = "IdLugarEntregaPago", @onchange = "getDireccionPago()" })
                    </div>
                </div>
                <div class="col-sm-4">
                    <div class="form-group">
                        <label>Mapa</label>
                        <div id="mapFirmaPago" style="width:350px;height:200px;"></div>
                    </div>
                </div>
            </div>


        }
    </div>
    <label>Datos facturación</label>
    <hr />
    <div class="container-fluid">
        <div class="row">
            <div class="col-sm-4">
                <div class="form-group">
                    <label>Nombre, denominación o razón social</label>
                    <input type="text" class="form-control" readonly value="@Model.datosFacturacion.Dependencia">

                </div>
            </div>
            <div class="col-sm-4">
                <div class="form-group">
                    <label>Clave de registro federal de contribuyentes</label>
                    <input type="text" class="form-control" readonly value="@Model.datosFacturacion.Rfc">
                </div>
            </div>
            <div class="col-sm-4">
                <div class="form-group">
                    <label>Calle</label>
                    <input type="text" class="form-control" readonly value="@Model.datosFacturacion.Calle">
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-sm-4">
                <div class="form-group">
                    <label>Número exterior</label>
                    <input type="text" class="form-control" readonly value="@Model.datosFacturacion.NoExterior">

                </div>
            </div>
            <div class="col-sm-4">
                <div class="form-group">
                    <label>Número interior</label>
                    <input type="text" class="form-control" readonly value="@Model.datosFacturacion.NoInterior">
                </div>
            </div>
            <div class="col-sm-4">
                <div class="form-group">
                    <label>Colonia</label>
                    <input type="text" class="form-control" readonly value="@Model.datosFacturacion.Colonia">
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-sm-4">
                <div class="form-group">
                    <label>País</label>
                    @Html.DropDownList("IdPais", ViewBag.lstPais as SelectList, "Seleccione Pais", new { @class = "form-control disabledClick", @Required = "", @id = "IdPais", @readonly = true })


                </div>
            </div>
            <div class="col-sm-4">
                <div class="form-group">
                    <label>Estado</label>
                    @Html.DropDownList("IdEstado", ViewBag.lstEstado as SelectList, "Seleccione Estado", new { @class = "form-control disabledClick", @Required = "", @id = "IdEstado", @readonly = true })
                </div>
            </div>
            <div class="col-sm-4">
                <div class="form-group">
                    <label>Municipio</label>
                    @Html.DropDownList("IdMunicipio", ViewBag.lstMunicipio as SelectList, "Seleccione Municipio", new { @class = "form-control disabledClick", @Required = "", @id = "IdMunicipio", @readonly = true })
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-sm-4">
                <div class="form-group">
                    <label>Localidad</label>
                    <input type="text" class="form-control" readonly value="@Model.datosFacturacion.Localidad">

                </div>
            </div>
            <div class="col-sm-4">
                <div class="form-group">
                    <label>Código postal</label>
                    <input type="text" class="form-control" readonly value="@Model.datosFacturacion.CodigoPostal">
                </div>
            </div>
            <div class="col-sm-4">
                <div class="form-group">
                    <label>Correo electrónico</label>
                    <input type="text" class="form-control" readonly value="@Model.datosFacturacion.Email">
                </div>
            </div>
        </div>
    </div>
    <hr />
    <div class="container-fluid @(activar) ">
        
            <div class="row">
                <div class="col-sm-4">

                    <div class="form-group form-inline">
                        <div class="col-sm-4">
                            Anticipo
                            
                            <div class="form-group  form-inline">
                                <div class="custom-control custom-radio">
                                    <input type="radio" id="customRadio1" name="customRadio" class="custom-control-input" value="1" @(Model.condicionPago.Anticipo ? "checked" : "")>
                                    <label class="custom-control-label" style="text-transform:capitalize !important" for="customRadio1">SI</label>
                                </div>
                                <div class="custom-control custom-radio">
                                    <input type="radio" id="customRadio2" name="customRadio" class="custom-control-input" value="0" @(!Model.condicionPago.Anticipo ? "checked" : "")>
                                    <label class="custom-control-label" style="text-transform:capitalize !important" for="customRadio2">NO</label>
                                </div>
                                <input type="hidden" id="IdAnticipoBool" />
                            </div>
                        </div>
                    <div class="col-sm-8">
                        <div class="form-group">
                            Porcentaje
                            @Html.DropDownList("IdAnticipo", ViewBag.lstAnticipo as SelectList, "Seleccione Anticipo", new { @class = "form-control", @Required = "", @id = "IdAnticipo", @onchange = "calcularPorcentaje()" })
                            <input type="hidden" value="@Model.condicionPago.PorcentajeAnticipo" id="porcentajeAplicado" />
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-sm-4">
                <div class="form-group">
                    <label>Número de pagos</label>
                    <input type="number" class="form-control" id="numeroPagosAGenerar" value="@Model.condicionPago.NumeroPagos" min="0">
                </div>
            </div>
            <div class="col-sm-4">


                <div class="form-group">
                    <label>Periodicidad</label>
                    <div class="input-group mb-3">
                        @Html.DropDownList("IdPeriodicidad", ViewBag.lstPeriodicidad as SelectList, "Seleccione periodicidad", new { @class = "form-control", @Required = "", @id = "IdPeriodicidad" })

                        <div class="input-group-append">
                            <button class="btn btn-secondary btn-sm" type="button" onclick="getCalculoPartida()">GENERAR PAGOS</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-sm-4">
                <div class="form-group">
                    <label>Anticipo</label>
                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text">$</span>
                        </div>
                        <input type="text" name="number" class="form-control" readonly id="ImporteAnticipo" value="@Model.condicionPago.ImporteAnticipo">
                    </div>
                </div>
            </div>
            <div class="col-sm-4">
                <div class="form-group">
                    <label>Total de los pagos</label>
                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text">$</span>
                        </div>
                        <input type="text" class="form-control" readonly name="number" value="@Model.condicionPago.ImporteTotalPagos" id="importeTotalPagosPendiente">
                    </div>



                </div>
            </div>
            <div class="col-sm-4">
                <div class="form-group">
                    <label>Importe total</label><br>
                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text">$</span>
                        </div>
                        <input type="text" class="form-control" readonly name="number" value="@Model.sumRequisicionLote" id="ImporteTotalPago">
                    </div>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-sm-4">
                <div class="form-group">
                    <label>Fecha Inicio Pagos</label>
                    <div class='input-group date'>
                        <input type='text' class="form-control datetimepickerPago" value="@String.Format("{0:yyyy-MM-dd}", Model.condicionPago.FechaInicioPago)" name="FechaInicioPago" id="FechaInicioPago" autocomplete="off" readonly />
                        <span class="input-group-addon">
                            <span class="glyphicon glyphicon-time"></span>
                        </span>
                    </div>
                </div>
            </div>
            <div class="col-sm-4">

            </div>
            <div class="col-sm-4">

            </div>
        </div>
    </div>
    <table id="tablaPagos" class="table table-striped table-bordered" width="100%">
        <thead style="width:100%">
            <tr>

                <th>Acciones</th>
                <th>Pago</th>
                <th>Monto</th>
                <th>Porcentaje</th>
                <th>Mes de pago</th>
                <th>Observación</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.condicionPagoDetalle)
            {
                <tr>
                    <td><div class="btn-group @(activar)"><button class="btn btn-secondary btn-sm (@item.bool1? '' : 'disabledClick')" style="margin-right:5px;" onclick="editarCondicionPagoDetalle(@item.id2)"><span class="fa fa-pencil"></span></button></div></td>
                    <td>@item.id</td>
                    <td style="text-align:right">@(String.Format("{0:C2}", item.decimal1))</td>
                    <td style="text-align:right">%@(String.Format("{0:N2}", item.decimal2))</td>
                    <td>@item.string1</td>
                    <td>@item.string2</td>
                </tr>
            }

        </tbody>
        <tfoot style="width:100%">
            <tr>
                <td></td>
                <td>Total</td>
                <td style="text-align:right">@(String.Format("{0:C2}", @Model.condicionPagoDetalle.Select(c => c.decimal1).Sum()))</td>
                <td style="text-align:right">@(String.Format("{0:N2}", @Model.condicionPagoDetalle.Select(c => c.decimal2).Sum())) %</td>
                <td></td>
                <td></td>
            </tr>

        </tfoot>
    </table>
</div>
