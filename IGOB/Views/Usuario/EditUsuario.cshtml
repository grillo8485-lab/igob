
<div class="modal fade" id="UsuarioModal" role="dialog">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header changeColorModal">
                <h4 class="modal-title"></h4>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            @using (Html.BeginForm(null, null, FormMethod.Post, new { @Class = "data-form" }))
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary()
            <div class="modal-body">

                <div class="row" id="PersonaEditar">
                    
                    <div class="col-md-2 text-right">Persona:</div>
                    <div class="col-md-10 ">
                        <div class="input-group col-md-12">
                            <input type="text" class="form-control" id="Persona" disabled="disabled">
                            <div class="input-group-append"  id="IdBuscar__">
                                <button type="button" class="btn btn-outline-secondary" onclick="buscarPersona() ">
                                    <span class="icon-search"></span>
                                </button>
                            </div>
                        </div>
                        <input type="hidden" name="IdPersona" id="IdPersona" value="0" />
                    </div>
                </div>
                <br />
                <div class="row" id="usuarioPassword">
                    <div class="col-md-2 text-right"><label>Usuario:</label></div>
                    <div class="col-md-4 text-left"> <input type="email" class="form-control" id="Usuario" placeholder="Introduce Usuario"></div>
                    <div class="col-md-2 text-right"><label>Contraseña:</label></div>
                    <div class="col-md-4 text-left"> <input type="password" class="form-control" id="Password" placeholder="Introduce Contraseña"></div>
                </div>
                <div class="row">
                    <div class="col-md-2 text-right">Perfil:</div>
                    <div class="col-md-10 text-left">
                        @if (ViewBag.TPListPerfiles != null)
                        {
                            @Html.DropDownList("IdPerfil", ViewBag.TPListPerfiles as SelectList, "Seleccione Perfil", new { @class = "form-control", @Required = "" })
                        }
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-2 text-right"><label>Correo Electronico:</label></div>
                    <div class="col-md-4 text-left"> <input type="text" class="form-control" id="CorreoElectronico" placeholder="Introduce Correo Electronico"></div>
                    <div class="col-md-2 text-right"><label>Activo:</label></div>
                    <div class="col-md-4 text-left">
                        <div class="input-group">
                            <div id="radioBtn" class="btn-group">
                                <a class="btn btn-primary btn-sm active" data-toggle="happy" id="Activo" data-title="S">SI</a>
                                <a class="btn btn-primary btn-sm notActive" data-toggle="happy" id="InActivo" data-title="N">NO</a>
                            </div>
                            <input type="hidden" name="happy" id="happy">
                        </div>

                    </div>
                </div>
                <input type="hidden" name="IdUsuario" id="IdUsuario" value="0" />

                <br /> <br />
                <div id="ResultadoBuscar">


                </div>
            </div>
            <div class="modal-footer">
                <input type="button" class="btn btn-default" data-dismiss="modal" value="Cerrar" />
                <input type="button" value="Guardar" class="btn btn-default" onclick="validarForm()" id="IdGuardar__"/>
                <input type="button" value="Actualizar" class="btn btn-default" onclick="guardarEdicion()" id="Actualizar__"/>
            </div>
            }
        </div>
    </div>
</div>
