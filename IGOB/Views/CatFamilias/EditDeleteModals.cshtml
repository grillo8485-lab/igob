<!-- Modal -->
<div class="modal fade" id="FamiliasModal" role="dialog">
    <div class="modal-dialog">
        <!-- Modal content-->
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">Editar Familia</h4>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            @using (Html.BeginForm(null, null, FormMethod.Post, new { @Id = "form-Fam" }))
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true)
                <div class="modal-body">
                    <div class="row col-12">
                        <div class="col-5">
                            <label> Nombre de la Familia: </label>  
                            <input type="text" id="Familia" name="Familia" required class="form-control" />
                        </div>
                        <div class="col-7">
                            <label> Descripción de la Familia: </label>  
                            <input type="text" id="Descripcion" name="Descripcion" required class="form-control" />
                        </div>
                    </div>
                    <input type="hidden" id="Activo" name="Activo" value="true" />
                    <input type="hidden" id="IdFamilia" name="IdFamilia" value="0" />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cerrar</button>
                    <input type="submit" value="Guardar" class="btn btn-secondary" />
                </div>
            }
        </div>
    </div>
</div>
<!-- End Modal Edit - New -->