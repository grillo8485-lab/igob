@{
    ViewBag.Title = "Reporte de Adquisiciones";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@Html.AntiForgeryToken()
@Html.ValidationSummary()

@{ iGob.Entidades.beRptAppEjecutivosLicitaciones obeRepAdq = ViewBag.obeRep;}

<div class="pos-f-t">
    <nav class="navbar bg-secondary text-white navbar-light bg-light changeColorModal">
        <div class="col-sm-4">

        </div>

        <div class="col-sm-8" style="text-align: right;">
            <button class="btn btn-default btn-circle btn-sm" type="button" onclick="printData()" id="btn_imprimir">IMPRIMIR</button>
        </div>
    </nav>
</div>

@if (ViewBag.IdPerfil == 11)
{
    <div style="color: #fff;background-color: #999;text-align:center;padding:5px;">Presupuesto del Estado</div>

    <div id="div_reporte" style="width:100%;overflow:auto;">
        <div id="tabla_datos" style="width:100%;overflow:auto;">
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Total adjudicado</th>
                        <th>Adjudicaciones directas</th>
                        <th>Restringidas</th>
                        <th>Licitaciones abiertas</th>
                        <th>Año</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>@obeRepAdq.MontoAdjudicadoTotal.ToString("C2")</td>
                        <td>@obeRepAdq.MontoTotalDirecta.ToString("C2")</td>
                        <td>@obeRepAdq.MontoTotalRestringida.ToString("C2")</td>
                        <td>@obeRepAdq.MontoTotalLicitaAbierta.ToString("C2")</td>
                        <td>@obeRepAdq.Ejercicio</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div id="div_grafica">
            <br />
            <div style="text-align:center;font-weight:bold;">
                Gobierno del Estado de @obeRepAdq.Estado<br />
                Adquisiciones @obeRepAdq.Ejercicio<br />
            </div>
            <div id="piechart_3d" style="width:100%;height:400px;"></div>
            <span>
                <b>Total adjudicado: @obeRepAdq.MontoAdjudicadoTotal.ToString("C2")</b><br />
                <b style="color:#f50057">Adjudicaciones directas: @obeRepAdq.MontoTotalDirecta.ToString("C2")</b><br />
                <b style="color:#ffa000">Restringidas: @obeRepAdq.MontoTotalRestringida.ToString("C2")</b><br />
                <b style="color:#6a1b9a">Licitaciones abiertas: @obeRepAdq.MontoTotalLicitaAbierta.ToString("C2")</b>
            </span>
        </div>
    </div>
}
else if (ViewBag.IdPerfil == 4)
{
    <div style="color: #fff;background-color: #999;text-align:center;padding:5px;">ADQUISICIONES @obeRepAdq.Dependencia</div>

    <div id="div_reporte" style="width:100%;overflow:auto;">
        <div id="tabla_datos" style="width:100%;overflow:auto;">
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Total adjudicado</th>
                        <th>Adjudicaciones directas</th>
                        <th>Restringidas</th>
                        <th>Licitaciones abiertas</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>@obeRepAdq.MontoAdjudicadoTotal.ToString("C2")</td>
                        <td>@obeRepAdq.MontoTotalDirecta.ToString("C2")</td>
                        <td>@obeRepAdq.MontoTotalRestringida.ToString("C2")</td>
                        <td>@obeRepAdq.MontoTotalLicitaAbierta.ToString("C2")</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div id="div_grafica">
            <br />
            <div style="text-align:center;font-weight:bold;">
                ADQUISICIONES<br />
                @obeRepAdq.Dependencia<br />
            </div>
            <div id="piechart_3d" style="width:100%;height:400px;"></div>
            <span>
                <b>Total adjudicado: @obeRepAdq.MontoAdjudicadoTotal.ToString("C2")</b><br />
                <b style="color:#f50057">Adjudicaciones directas: @obeRepAdq.MontoTotalDirecta.ToString("C2")</b><br />
                <b style="color:#ffa000">Restringidas: @obeRepAdq.MontoTotalRestringida.ToString("C2")</b><br />
                <b style="color:#6a1b9a">Licitaciones abiertas: @obeRepAdq.MontoTotalLicitaAbierta.ToString("C2")</b>
            </span>
        </div>
    </div>
}


@section scripts{
    <script type="text/javascript" src="https://www.gstatic.com/charts/loader.js"></script>

    <script type="text/javascript">
    google.charts.load("current", { packages: ["corechart"] });
    google.charts.setOnLoadCallback(drawChart);

    function drawChart() {
        var dataTable = new google.visualization.DataTable();
        dataTable.addColumn('string', 'Descripcion');
        dataTable.addColumn('number', 'Cantidad');
        // A column for custom tooltip content
        dataTable.addColumn({ type: 'string', role: 'tooltip' });
        dataTable.addRows([
            ['Adjudicaciones Directas: @obeRepAdq.MontoTotalDirecta.ToString("C2")', @obeRepAdq.MontoTotalDirecta, 'Presupuesto Ejercido: @obeRepAdq.MontoTotalDirecta.ToString("C2")'],
            ['Restringidas: @obeRepAdq.MontoTotalRestringida.ToString("C2")', @obeRepAdq.MontoTotalRestringida, 'Economias: @obeRepAdq.MontoTotalRestringida.ToString("C2")'],
            ['Licitaciones Abiertas: @obeRepAdq.MontoTotalLicitaAbierta.ToString("C2")', @obeRepAdq.MontoTotalLicitaAbierta, 'Presupuesto pendiente por ejercer:  @obeRepAdq.MontoTotalLicitaAbierta.ToString("C2")']
        ]);

        var formatter = new google.visualization.NumberFormat({
            prefix: '$'
        });
        formatter.format(dataTable, 1);

        var options = {
            legend: { position: 'none' },
            is3D: true,
            pieSliceText: 'value',
            sliceVisibilityThreshold: 0,
            colors: ['#f50057', '#ffa000', '#6a1b9a'],
            chartArea: { 'width': '100%', 'height': '80%' },
        };

        var chart = new google.visualization.PieChart(document.getElementById('piechart_3d'));
        chart.draw(dataTable, options);
    }

    </script>

    <script>

    function printData() {
        var divToPrint = document.getElementById("tabla_datos");
        var divGrafica = document.getElementById("div_grafica");
        var htmlToPrint = '' +
            '<style type="text/css">' +
            'table { border-collapse:collapse;}'+
            'table th, table td {border:1px solid #000; padding:0.5em;}' +
            '</style>';
        
        @if (ViewBag.IdPerfil == 11)
        {
            @:var encabezado = '<center><b>Gobierno del Estado de @obeRepAdq.Estado</b><br><b>Adquisiciones</b><br></center><br>';
        }else if (ViewBag.IdPerfil == 4)
        {
            @:var encabezado = '<center><b>@obeRepAdq.Dependencia</b><br><b> ADQUISICIONES</b><br>';
        }
        newWin = window.open("");
        newWin.document.write(htmlToPrint + encabezado + divToPrint.outerHTML + divGrafica.outerHTML);
        newWin.print();
        newWin.close();
    }
    </script>
}
