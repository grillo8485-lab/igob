@{
    ViewBag.Title = "Presupuesto Dependencia";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@Html.AntiForgeryToken()
@Html.ValidationSummary()

@{ iGob.Entidades.beRptAppEjecutivosLicitaciones obeRepPre = ViewBag.obeRep;}

<div class="pos-f-t">
    <nav class="navbar bg-secondary text-white navbar-light bg-light changeColorModal">
        <div class="col-sm-4">

        </div>

        <div class="col-sm-8" style="text-align: right;">
            <button class="btn btn-default btn-circle btn-sm" type="button" onclick="printData()" id="btn_imprimir">IMPRIMIR</button>
        </div>
    </nav>
</div>

@if (ViewBag.IdPerfil == 11)
{
    <div style="color: #fff;background-color: #999;text-align:center;padding:5px;">Presupuesto del Estado de @obeRepPre.Estado</div>

    <div id="div_reporte" style="width:100%;overflow:auto;">
        <div id="tabla_datos" style="width:100%;overflow:auto;">
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Presupuesto para dependencias y entidades</th>
                        <th>Presupuesto ejercido</th>
                        <th>Presupuesto por ejercer</th>
                        <th>Economías</th>
                        <th>Año</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>@obeRepPre.MontoPresupuestadoTotal.ToString("C2")</td>
                        <td>@obeRepPre.MontoTotalEjercido.ToString("C2")</td>
                        <td>@obeRepPre.MontoxEjercer.ToString("C2")</td>
                        <td>@obeRepPre.Economia.ToString("C2")</td>
                        <td>@obeRepPre.Ejercicio</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div id="div_grafica">
            <br />
            <div style="text-align:center;">
                <b>
                    Gobierno del Estado de @obeRepPre.Estado<br />
                    Presupuesto total asignado para adquisiciones <br />
                    Ejercicio @obeRepPre.Ejercicio
                </b>
            </div>
            <div id="piechart_3d" style="width:100%;height:400px;"></div>
            <span>
                <b>Presupuesto para dependencias y entidades: @obeRepPre.MontoPresupuestadoTotal.ToString("C2")</b><br />
                <b style="color:#c00000">Presupuesto Ejercido: @obeRepPre.MontoTotalEjercido.ToString("C2")</b><br />
                <b style="color:#00c000">Presupuesto pendiente por ejercer: @obeRepPre.MontoxEjercer.ToString("C2")</b><br />
                <b style="color:#0000c0">Economias: @obeRepPre.Economia.ToString("C2")</b><br />
            </span>
        </div>

    </div>
}
else if (ViewBag.IdPerfil == 4)
{
    <div style="color: #fff;background-color: #999;text-align:center;padding:5px;">PRESUPUESTO DE ADQUISICIONES <br /> @obeRepPre.Dependencia</div>

    <div id="div_reporte" style="width:100%;overflow:auto;">
        <div id="tabla_datos" style="width:100%;overflow:auto;">
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Presupuesto total</th>
                        <th>Presupuesto ejercido</th>
                        <th>Presupuesto por ejercer</th>
                        <th>Economías</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>@obeRepPre.PresupuestoDependencia.ToString("C2")</td>
                        <td>@obeRepPre.PresupuestoEjercido.ToString("C2")</td>
                        <td>@obeRepPre.PresupuestoxEjercer.ToString("C2")</td>
                        <td>@obeRepPre.MontoTotalEconomia.ToString("C2")</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div id="div_grafica">
            <br />
            <div style="text-align:center;">
                <b>
                    @obeRepPre.Dependencia<br />
                    Presupuesto total asignado para adquisiciones <br />
                </b>
            </div>
            <div id="piechart_3d" style="width:100%;height:400px;"></div>
            <span>
                <b>Presupuesto total: @obeRepPre.PresupuestoDependencia.ToString("C2")</b><br />
                <b style="color:#c00000">Presupuesto Ejercido: @obeRepPre.PresupuestoEjercido.ToString("C2")</b><br />
                <b style="color:#00c000">Presupuesto pendiente por ejercer: @obeRepPre.PresupuestoxEjercer.ToString("C2")</b><br />
                <b style="color:#0000c0">Economias: @obeRepPre.MontoTotalEconomia.ToString("C2")</b><br />
            </span>
        </div>

    </div>
}



@section scripts{

    <script type="text/javascript" src="https://www.gstatic.com/charts/loader.js"></script>

    <script type="text/javascript">
    google.charts.load("current", { packages: ["corechart"] });
    google.charts.setOnLoadCallback(drawChart);

    function drawChart() {
        var dataTable = new google.visualization.DataTable();
        dataTable.addColumn('string', 'Descripcion');
        dataTable.addColumn('number', 'Cantidad');
        // A column for custom tooltip content
        dataTable.addColumn({ type: 'string', role: 'tooltip' });

        @if (ViewBag.IdPerfil == 11)
        {
            <text>
            dataTable.addRows([
                ['Presupuesto Ejercido: @obeRepPre.MontoTotalEjercido.ToString("C2")', @obeRepPre.MontoTotalEjercido, 'Presupuesto Ejercido: @obeRepPre.MontoTotalEjercido.ToString("C2")'],
                ['Presupuesto pendiente por ejercer: @obeRepPre.MontoxEjercer.ToString("C2")', @obeRepPre.MontoxEjercer, 'Presupuesto pendiente por ejercer:  @obeRepPre.MontoxEjercer.ToString("C2")'],
                ['Economias: @obeRepPre.Economia.ToString("C2")', @obeRepPre.Economia, 'Economias: @obeRepPre.Economia.ToString("C2")']
             ]);
            </text>
        }else if (ViewBag.IdPerfil == 4)
        {
            <text>
            dataTable.addRows([
                ['Presupuesto Ejercido: @obeRepPre.PresupuestoEjercido.ToString("C2")', @obeRepPre.PresupuestoEjercido, 'Presupuesto Ejercido: @obeRepPre.PresupuestoEjercido.ToString("C2")'],
                ['Presupuesto pendiente por ejercer: @obeRepPre.PresupuestoxEjercer.ToString("C2")', @obeRepPre.PresupuestoxEjercer, 'Presupuesto pendiente por ejercer:  @obeRepPre.PresupuestoxEjercer.ToString("C2")'],
                ['Economias: @obeRepPre.MontoTotalEconomia.ToString("C2")', @obeRepPre.MontoTotalEconomia, 'Economias: @obeRepPre.MontoTotalEconomia.ToString("C2")']
             ]);
            </text>
        }


        var formatter = new google.visualization.NumberFormat({
            prefix: '$'
        });
        formatter.format(dataTable, 1);

        var options = {
            legend: { position: 'none' },
            is3D: true,
            pieSliceText: 'value',
            sliceVisibilityThreshold: 0,
            colors: ['#c00000', '#00c000', '#0000c0'],
            chartArea: { 'width': '100%', 'height': '80%' },
        };

        var chart = new google.visualization.PieChart(document.getElementById('piechart_3d'));
        chart.draw(dataTable, options);
    }

    </script>

    <script>

    function printData() {
        var divToPrint = document.getElementById("tabla_datos");
        var divGrafica = document.getElementById("div_grafica");
        var htmlToPrint = '' +
            '<style type="text/css">' +
            'table { border-collapse:collapse;}'+
            'table th, table td {border:1px solid #000; padding:0.5em;}' +
            '</style>';
        @if (ViewBag.IdPerfil == 11)
        {
            @:var encabezado = '<center><b>Gobierno del Estado de @obeRepPre.Estado</b><br><b>Presupuesto total asignado para adquisiciones</b><br>';
        }else if (ViewBag.IdPerfil == 4)
        {
            @:var encabezado = '<center><b>PRESUPUESTO DE ADQUISICIONES</b><br><b> @obeRepPre.Dependencia</b><br>';
        }

        newWin = window.open("");
        newWin.document.write(htmlToPrint + encabezado + divToPrint.outerHTML + divGrafica.outerHTML);
        newWin.print();
        newWin.close();
    }
    </script>
}