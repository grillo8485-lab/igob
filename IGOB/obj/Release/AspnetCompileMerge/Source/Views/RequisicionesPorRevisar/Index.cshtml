@model IGOB.Models.Requisicion

@{
    ViewBag.Title = "Requisiciones por revisar";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@section css{
    <link href="~/Content/jquery-ui.css" rel="stylesheet" />
    <link href="~/Content/jquery-ui.structure.css" rel="stylesheet" />
    <link href="~/Content/jquery-ui.theme.css" rel="stylesheet" />
    <link href="~/Content/bootstrap-datetimepicker.css" rel="stylesheet" />
}

<!-- estilo pills personalizado -->
<style>
    #pac-input {
        width: 100%;
    }

    .col-12 {
        margin-bottom: 15px !important;
    }

    .pac-container {
        z-index: 9999;
    }

    #map {
        width: 100% !important;
        height: 15vw !important;
    }

    .dataTables_filter {
        text-align: right;
    }

    .error {
        color: red !important;
    }

    .sub_banner {
        padding: 10.5px;
        margin-top: 15px
    }

        .sub_banner strong {
            font-size: 9.94pt;
        }

    input[type=number] {
        text-align: right;
    }

    input[name=number] {
        text-align: right;
    }
</style>
<div class="">
    <input type="hidden" id="Formulario" value="@ViewBag.formulario" />
    <input type="hidden" id="IdRequisicion" value="@ViewBag.idRequisicion" />
    <input type="hidden" id="tipoRequisicion" value="@ViewBag.tipoRequisicion" />
    <input type="hidden" id="IdTipoSolicitud" value="@Model.oRequisicones.IdTipoSolicitud" />
    <input type="hidden" id="cartaActivo" value="@Model.Activar" />
    <div class="pos-f-t">
        <div class="mainMenuBarAnchor"></div>
        <nav class="navbar bg-secondary text-white navbar-light bg-light changeColorModal mainMenuBar">
            <div class="row col-12">
                <div class="col-1 text-left">
                    <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarToggleExternalContent" aria-controls="navbarToggleExternalContent" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                </div>
                <div class="col-7 text-center">
                    <h6>@Model.Titulo</h6>
                </div>

                <div class="col-4 text-right">
                    @switch (Model.IdPerfil)
                    {
                        case 7:

                            <input type="button" class="btn btn-default btn-sm" name="" value="Autorizar" id="AutorizarRevision" @ViewBag.inactivo >
                            <input type="button" class="btn btn-default btn-sm" name="" value="Rechazar" id="RechazarRevision" @ViewBag.inactivo>
                            break;
                        case 5:
                            <input type="button" class="btn btn-default btn-sm" name="btnAutorizarDirector" value="Autorizar" id="btnAutorizarDirector" @ViewBag.inactivo @((ViewBag.reqFirm.ValidaCondicionEntregaRevisor == false || ViewBag.reqFirm.ValidaLotesRevisor == false || ViewBag.reqFirm.ValidaCondicionPagoRevisor == false)?"disabled":"")>
                            <input type="button" class="btn btn-default btn-sm" name="btnCancelarDirector" value="Rechazar" id="btnCancelarDirector" @ViewBag.inactivo>
                            break;
                    }

                    <button class="btn btn-default  btn-sm" onclick="retornarPagina(@ViewBag.tipoRequisicion)">REGRESAR</button>
                </div>
                            </div>
                        </nav>
                        <div class="collapse changeColorModal show" id="navbarToggleExternalContent">
                            <div class="bg-light p-1 ">
                                <ul class="nav nav-pills" role="tablist">
                                    <li class="nav-item">
                                        <a class="nav-link active" data-toggle="pill" href="#DatosGenerales" id="DatosGeneralesTabPadre">DATOS GENERALES</a>
                                    </li>

                                    <li class="nav-item">
                                        <a class="nav-link" data-toggle="pill" href="#div_presupuesto_liquidez" id="div_presupuesto_liquidezTabPadre">PRESUPUESTO Y LIQUIDEZ</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link" data-toggle="pill" href="#div_cartas" id="div_cartasTabPadre">CARTAS</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link" data-toggle="pill" href="#div_lotes" id="div_lotesTabPadre">LOTES</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link" data-toggle="pill" href="#div_condiciones_entrega" id="div_condiciones_entregaTabPadre">CONDICIONES DE ENTREGA</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link" data-toggle="pill" href="#div_condiciones_pago" id="div_condiciones_pagoTabPadre">CONDICIONES DE PAGO</a>
                                    </li>
                                    

                                    <li class="nav-item">
                                        <a class="nav-link" data-toggle="pill" href="#div_firmantes" id="div_firmantesTabPadre">FIRMANTES</a>
                                    </li>

                                </ul>
                            </div>
                        </div>
                    </div>
                    <div id="ResultadoBuscar"></div>
                    <div class="tab-content">
                        @Html.AntiForgeryToken()
                        @Html.ValidationSummary()

                        @{
                            <!-- Datos Generales -->
                            Html.RenderPartial("DatosGenerales");
                            <!-- PRESUPUESTO Y LIQUIDEZ -->
                            Html.RenderPartial("PresupuestoLiquidez");
                            <!-- CARTAS -->
                            Html.RenderPartial("Cartas");
                            <!-- LOTES -->
                            Html.RenderPartial("Lotes");
                            <!-- CONDICIONES DE ENTREGA -->
                            Html.RenderPartial("CondicionesEntrega");
                            <!-- CONDICIONES DE PAGO -->
                            Html.RenderPartial("CondicionesPago");
                            
                            <!-- FIRMANTES -->
                            Html.RenderPartial("Firmantes");
                        }

                    </div>
                    <div class="modal fade" id="Pop-Up" role="dialog">
                        <div class="modal-dialog">
                            <div class="modal-content">
                                <div class="modal-header changeColorModal">
                                    <h4 class="modal-title">Requisición Monto</h4>
                                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                                </div>
                                @using (Html.BeginForm(null, null, FormMethod.Post))
                                {
                                    @Html.AntiForgeryToken()
                                    @Html.ValidationSummary(true)
                                    <div class="modal-body">
                                        <br />
                                        <h4 id="titlePopUp"></h4>
                                    </div>
                                    <div class="modal-footer">
                                        <input type="button" class="btn btn-default" data-dismiss="modal" value="Cerrar" />
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
                @section scripts{
                    <script>

$(document).ready(function () {
// Cache selectors for faster performance.
var $window = $(window),
$mainMenuBar = $('.mainMenuBar'),
$mainMenuBarAnchor = $('.mainMenuBarAnchor');

// Run this on scroll events.
$window.scroll(function () {
var window_top = $window.scrollTop();
var div_top = $mainMenuBarAnchor.offset().top;
var diff = (Math.abs((window_top - 9 )- (div_top)));

if (diff < 9) {
return false;
}else if(window_top > div_top) {
// Make the div sticky.
$mainMenuBar.addClass('stick');
$mainMenuBarAnchor.height($mainMenuBar.height());
}
else {
// Unstick the div.s
$mainMenuBar.removeClass('stick');
$mainMenuBarAnchor.height(0);
}
});
});
                    </script>
                    <script src="~/Scripts/jquery-ui.js"></script>
                    <script src="~/Scripts/Catalogos/Requisiciones.js"></script>
                    <script src="~/Scripts/Catalogos/RequisicionRevisorFirmante.js"></script>
                    <script src="https://maps.googleapis.com/maps/api/js?key=AIzaSyCZRXUq794gmdIcVRUS0toiAQD9MnQEFYg&libraries=places&callback=initAutocomplete" async defer></script> <!--Modal-->

                    <script src="~/Scripts/inputMap.js"></script>
                }