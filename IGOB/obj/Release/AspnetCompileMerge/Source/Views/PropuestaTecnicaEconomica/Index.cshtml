@model IGOB.Models.Requisicion

@{
    ViewBag.Title = "Requisiciones Menores";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@section css{
    <link href="~/Content/jquery-ui.css" rel="stylesheet" />
    <link href="~/Content/jquery-ui.structure.css" rel="stylesheet" />
    <link href="~/Content/jquery-ui.theme.css" rel="stylesheet" />
    <link href="~/Content/bootstrap-datetimepicker.css" rel="stylesheet" />
}
<!-- estilo pills personalizado -->
<style>
    #pac-input {
        width: 100%;
    }
    .dataTables_scrollHeadInner {
        width: 100% !important;
    }
    .table {
        width: 100% !important;
    }
    .col-12 {
        margin-bottom: 15px !important;
    }

    .pac-container {
        z-index: 9999;
    }

    #map {
        width: 100% !important;
        height: 15vw !important;
    }

    .dataTables_filter {
        text-align: right;
    }

    .error {
        color: red !important;
    }

    .sub_banner {
        margin-top: 15px
    }

        .sub_banner strong {
            font-size: 9.94pt;
        }

    input[type=number] {
        text-align: right;
    }

    input[name=number] {
        text-align: right;
    }

    .verSeccion {
        display: none;
    }
</style>
<div class="">
    <input type="hidden" id="Formulario" value="@ViewBag.formulario" />
    <input type="hidden" id="IdRequisicion" value="@ViewBag.idRequisicion" />
    <input type="hidden" id="tipoRequisicion" value="@ViewBag.tipoRequisicion" />
    <input type="hidden" id="IdTipoSolicitud" value="@Model.oRequisicones.IdTipoSolicitud" />
    <input type="hidden" id="cartaActivo" value="@Model.Activar" />
    <input type="hidden" id="Diferencia" value="@ViewBag.Diferencia" />
    <input type="hidden" id="IdProveedorRqInvitacion" value="@ViewBag.IdProveedorRqInvitacion" />
    <input type="hidden" id="idPerfil" value="@ViewBag.idPerfil" />
    <div class="pos-f-t">
        <div class="mainMenuBarAnchor" style="height: 0px;"></div>
        <nav class="navbar bg-secondary text-white navbar-light bg-light changeColorModal mainMenuBar">
            <div class="row col-12">
                <div class="col-1 text-left">
                    <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarToggleExternalContent" aria-controls="navbarToggleExternalContent" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                </div>
                <div class="col-6 text-center">
                    <h6>@Model.Titulo</h6>
                </div>

                <div class="col-5 text-right">


                    @switch (@ViewBag.idPerfil)
                    {
                        case 7:
                            switch (@Model.IdTipoPropuesta)
                            {

                                case 3:
                                    <button type="button" class="btn btn-default btn-sm @((Model.oProveedoresRequisicionesInvitacion.IdEstatusEnvioPropuestaTecnica == 2) ? "" : "disabledClick")" id="btnRecibirPropRev" onclick="@((Model.oProveedoresRequisicionesInvitacion.IdEstatusEnvioPropuestaTecnica == 2) ? "AutorizarPropTecEcoRevisor(" + @Model.IdTipoPropuesta + ")" : "")">RECIBIDO TÉCNICA</button>
                                    break;
                                case 4:
                                    <button type="button" class="btn btn-default btn-sm @((Model.oProveedoresRequisicionesInvitacion.IdEstatusEnvioPropuestaEconomica == 2) ? "" : "disabledClick")" id="btnRecibirPropRev" onclick="@((Model.oProveedoresRequisicionesInvitacion.IdEstatusEnvioPropuestaEconomica == 2) ? "AutorizarPropTecEcoRevisor(" + @Model.IdTipoPropuesta + ")" : "")">RECIBIDO ECONÓMICA</button>
                                    break;
                                case 6:

                                    <button type="button" class="btn btn-default btn-sm verSeccion @Model.activarLotes" onclick="validarAceptarDictamenTecnico(1)" id="btnAceptarDictamenTecnico">ACEPTAR</button>
                                    <button type="button" class="btn btn-default btn-sm verSeccion @Model.activarLotes" onclick="validarAceptarDictamenTecnico(0)" id="btnRechazarDictamenTecnico">RECHAZAR</button>
                                    <button type="button" class="btn btn-default btn-sm verSeccion @Model.activarLotes" onclick="validarDatosDictamenTecnicoSolictante()" id="btnGuardarValidacionesDictamenTecnico">GUARDAR</button>

                                    break;
                            }
                            break;
                        case 8:
                            switch (@Model.IdTipoPropuesta)
                            {
                                case 1:
                                case 2:
                                    <button type="button" class="btn btn-default btn-sm @Model.visibleEconimica @Model.activar" onclick="validarEnviaPropuestaEconomica()" id="btnGEnviaPropuestaEconomica">ENVIAR PROPUESTA ECONÓMICA</button>
                                    <button type="button" class="btn btn-default btn-sm @Model.visibleTecnica @Model.activar" onclick="validarEnviaPropuestaTecnica()" id="btnGEnviaPropuestaTecnica">ENVIAR PROPUESTA TÉCNICA</button>
                                    <button type="button" class="btn btn-default btn-sm verSeccion @Model.activar" onclick="validarFormulario()" id="btnGuardarValidaciones">GUARDAR</button>
                                    break;

                            }
                            break;
                        case 3:

                            <button type="button" class="btn btn-default btn-sm verSeccion @Model.activarLotes" onclick="validarDictamenTecnicoSolictante()" id="btnEnviarDictamenTecnico">ENVIAR DICTAMEN</button>
                            <button type="button" class="btn btn-default btn-sm verSeccion @Model.activarLotes" onclick="validarDatosDictamenTecnicoSolictante()" id="btnGuardarValidacionesDictamenTecnico">GUARDAR</button>

                            break;


                    }
                    <button class="btn btn-default  btn-sm" onclick="location.href='@Url.Action("Index", "ListadoRequisicionLicitacion")'"><span class="glyphicon glyphicon-step-backward"></span>REGRESAR</button>

                </div>
            </div>
        </nav>
        <div class="collapse changeColorModal show" id="navbarToggleExternalContent">
            <div class="bg-light p-1 " id="activarDiv">
                @switch (@ViewBag.idPerfil)
                {
                    case 7:
                        switch (@Model.IdTipoPropuesta)
                        {


                            case 4:
                                <ul class="nav nav-pills" role="tablist">
                                    <li class="nav-item">
                                        <a class="nav-link active" data-toggle="pill" href="#div_lotes" id="div_lotesTabPadre">LOTES</a>
                                    </li>

                                </ul>
                                break;
                            case 6:

                                <ul class="nav nav-pills" role="tablist">
                                    <li class="nav-item">
                                        <a class="nav-link active" data-toggle="pill" href="#div_lotes" id="div_lotesTabPadre">LOTES</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link" data-toggle="pill" href="#div_cartas" id="div_cartasTabPadre">CARTAS</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link" data-toggle="pill" href="#div_condiciones_entrega" id="div_condiciones_entregaTabPadre">CONDICIONES DE ENTREGA</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link" data-toggle="pill" href="#div_condiciones_pago" id="div_condiciones_pagoTabPadre">CONDICIONES DE PAGO</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link" data-toggle="pill" href="#div_Requisitos_Adicionales" id="div_Requisitos_AdicionalesTabPadre">REQUISITOS ADICIONALES</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link" data-toggle="pill" href="#div_Enviar_PropuestaTecnica" id="div_Enviar_PropuestaTecnicaTabPadre">ENVIAR PROPUESTA TÉCNICA</a>
                                    </li>
                                </ul>
                                break;
                        }
                        break;
                    case 8:
                        switch (@Model.IdTipoPropuesta)
                        {
                            case 1:
                                <ul class="nav nav-pills" role="tablist">
                                    <li class="nav-item">
                                        <a class="nav-link active" data-toggle="pill" href="#div_lotes" id="div_lotesTabPadre">LOTES</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link" data-toggle="pill" href="#div_cartas" id="div_cartasTabPadre">CARTAS</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link" data-toggle="pill" href="#div_condiciones_entrega" id="div_condiciones_entregaTabPadre">CONDICIONES DE ENTREGA</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link" data-toggle="pill" href="#div_condiciones_pago" id="div_condiciones_pagoTabPadre">CONDICIONES DE PAGO</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link" data-toggle="pill" href="#div_Requisitos_Adicionales" id="div_Requisitos_AdicionalesTabPadre">REQUISITOS ADICIONALES</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link" data-toggle="pill" href="#div_Enviar_PropuestaTecnica" id="div_Enviar_PropuestaTecnicaTabPadre">ENVIAR PROPUESTA TÉCNICA</a>
                                    </li>
                                </ul>
                                break;
                            case 2:
                                <ul class="nav nav-pills" role="tablist">
                                    <li class="nav-item">
                                        <a class="nav-link active" data-toggle="pill" href="#div_lotes" id="div_lotesTabPadre">LOTES</a>
                                    </li>
                                </ul>
                                break;

                        }
                        break;
                    case 3:

                        <ul class="nav nav-pills" role="tablist">
                            <li class="nav-item">
                                <a class="nav-link active" data-toggle="pill" href="#div_lotes" id="div_lotesTabPadre">LOTES</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" data-toggle="pill" href="#div_cartas" id="div_cartasTabPadre">CARTAS</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" data-toggle="pill" href="#div_condiciones_entrega" id="div_condiciones_entregaTabPadre">CONDICIONES DE ENTREGA</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" data-toggle="pill" href="#div_condiciones_pago" id="div_condiciones_pagoTabPadre">CONDICIONES DE PAGO</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" data-toggle="pill" href="#div_Requisitos_Adicionales" id="div_Requisitos_AdicionalesTabPadre">REQUISITOS ADICIONALES</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" data-toggle="pill" href="#div_Enviar_PropuestaTecnica" id="div_Enviar_PropuestaTecnicaTabPadre">REVISAR PROPUESTA TÉCNICA</a>
                            </li>
                        </ul>
                        break;

                }

            </div>
        </div>
    </div>
    <div id="ResultadoBuscar"></div>
    <!-- Nav pills -->
    <!-- Tab panes -->
    <div class="tab-content">
        @Html.AntiForgeryToken()
        @Html.ValidationSummary()

        @{
            if (ViewBag.idPerfil != 7)
            {
                <!-- LOTES -->
                Html.RenderPartial("Lotes");
                <!-- Cartas -->
                Html.RenderPartial("Cartas");
                <!-- CONDICIONES DE ENTREGA -->
                Html.RenderPartial("CondicionesEntrega");
                <!-- CONDICIONES DE PAGO -->
                Html.RenderPartial("CondicionesPago");
                <!-- RequisitosAdicionales -->
                Html.RenderPartial("RequisitosAdicionales");
                <!-- ValidarPropuestaTecnica -->
                Html.RenderPartial("ValidarPropuestaTecnica");
            }
            else
            {
                switch (Model.IdTipoPropuesta)
                {
                    case 3:
                        Html.RenderPartial("LotesValidarPropuestaTecnica");
                        break;
                    case 4:
                        Html.RenderPartial("PropEconomica");
                        break;
                    case 6:
                        <!-- LOTES -->
                        Html.RenderPartial("Lotes");
                        <!-- Cartas -->
                        Html.RenderPartial("Cartas");
                        <!-- CONDICIONES DE ENTREGA -->
                        Html.RenderPartial("CondicionesEntrega");
                        <!-- CONDICIONES DE PAGO -->
                        Html.RenderPartial("CondicionesPago");
                        <!-- RequisitosAdicionales -->
                        Html.RenderPartial("RequisitosAdicionales");
                        <!-- ValidarPropuestaTecnica -->
                        Html.RenderPartial("ValidarPropuestaTecnica");
                        break;
                }
            }
        }

    </div>
</div>
@section scripts{
    <script>

$(document).ready(function () {
// Cache selectors for faster performance.
var $window = $(window),
$mainMenuBar = $('.mainMenuBar'),
$mainMenuBarAnchor = $('.mainMenuBarAnchor');

// Run this on scroll events.
$window.scroll(function () {
var window_top = $window.scrollTop();
var div_top = $mainMenuBarAnchor.offset().top;
var diff = (Math.abs((window_top - 9 )- (div_top)));

if (diff < 9) {
return false;
}else if(window_top > div_top) {
// Make the div sticky.
$mainMenuBar.addClass('stick');
$mainMenuBarAnchor.height($mainMenuBar.height());
}
else {
// Unstick the div.s
$mainMenuBar.removeClass('stick');
$mainMenuBarAnchor.height(0);
}
});
});
    </script>
    <script src="~/Scripts/jquery-ui.js"></script>
    <script src="~/Scripts/Catalogos/PropuestaTecnicaEconomica.js"></script>
    <script src="https://maps.googleapis.com/maps/api/js?key=AIzaSyCZRXUq794gmdIcVRUS0toiAQD9MnQEFYg&libraries=places&callback=initAutocomplete" async defer></script> <!--Modal-->

    <script src="~/Scripts/inputMap.js"></script>
}