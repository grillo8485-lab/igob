    <br />
    <table class="table-bordered hover" id="condicionesDeEntragaTable" width="100%">
        <thead>
            <tr>

                <th>Número</th>
                <th>Lote</th>
                <th>Cantidad Entrega</th>
                <th>Lugar Entrega</th>
                <th>Domicilio Entrega</th>
                <th>Mapa</th>
                <th>Horario Inicio Entrega</th>
                <th>Horario Fin Entrega</th>
                <th>Dias Entrega</th>
            </tr>
        </thead>
        <tbody>
            @{var i = 1;}
            @foreach (var item in Model.lstRequisicionCondicionesEntregaDetalleConsulta)
            {
                <tr>

                    <td>@item.NumeroEntrega</td>
                    <td>@item.NoLote</td>
                    <td align="right">@item.CantidadEntregaDetalle</td>
                    <td>@item.Lugar</td>
                    <td>@item.DomicilioEntrega</td>

                    <td style="width:200px;height:200px;">
                        <div id="mapValida-@i" class="mapValida disabledClick" style="width:150px;height:150px">
                        </div>
                        <input type="hidden" class="inptValida" value="@item.LocalizacionGoogle"  id="hiddenValida-@i" />
                    </td>
                    <td>@item.HorarioInicio</td>
                    <td>@item.HorarioFinal</td>
                    <td>
                        @if (item.Lunes == 1)
                        {
                            <button type="button" class="btn btn-secondary btn-sm"><span class="badge badge-light">Lunes</span></button>
                        }
                        @if (item.Martes == 1)
                        {
                            <button type="button" class="btn btn-secondary btn-sm"><span class="badge badge-light">Martes</span></button>
                        }
                        @if (item.Miercoles == 1)
                        {
                            <button type="button" class="btn btn-secondary btn-sm"><span class="badge badge-light">Miercoles</span></button>
                        }
                        @if (item.Jueves == 1)
                        {
                            <button type="button" class="btn btn-secondary btn-sm"><span class="badge badge-light">Jueves</span></button>
                        }
                        @if (item.Viernes == 1)
                        {
                            <button type="button" class="btn btn-secondary btn-sm"><span class="badge badge-light">Viernes</span></button>
                        }
                        @if (item.Sabado == 1)
                        {
                            <button type="button" class="btn btn-secondary btn-sm"><span class="badge badge-light">Sabado</span></button>
                        }
                        @if (item.Domingo == 1)
                        {
                            <button type="button" class="btn btn-secondary btn-sm"><span class="badge badge-light">Domingo</span></button>
                        }


                    </td>
                </tr>
                { i++; }
            }
        </tbody>
    </table>
    <br />
    <div id="CargaCondicionesEntregaPanel2" >
        <div class="row form-group @Model.visibleTecnicaSolicitante">
            <div class="col-md-2 text-right">Cumple con lo ofertado (condiciones de entrega):</div>
            <div class="col-md-2 text-left input-group">
                <label>@(Model.oProveedoresRequisicionesInvitacion.CondicionEntregaDependenciaCumple ? "Si" : "No")</label>
            </div>
            <div class="col-md-2 text-right">Observaciones y fundamentación legal:</div>
            <div class="col-md-6 text-left">
                <textarea id="CondicionEntregaFundamento" name="CondicionEntregaFundamento" rows="3" cols="33" class="form-control disabledClick">@Model.oProveedoresRequisicionesInvitacion.CondicionEntregaFundamento</textarea>
            </div>
        </div>
        <div class="row form-group @Model.visibleTecnicaRevisor">
            <div class="col-md-2 text-right">Rechazar:</div>
            <div class="col-md-2 text-left  input-group">
                <label>@(Model.oProveedoresRequisicionesInvitacion.CondicionEntregaAdquisicionCumple ? "Si" : "No")</label>
            </div>
            <div class="col-md-2 text-right">Observaciones adquisición</div>
            <div class="col-md-6 text-left">
                <textarea id="CondicionEntregaAdqObservacion" name="CondicionEntregaAdqObservacion" rows="3" cols="33" class="form-control disabledClick">@Model.oProveedoresRequisicionesInvitacion.CondicionEntregaAdqObservacion</textarea>
            </div>
        </div>
    </div>
</div>
@*seccion requisitos adicionales*@
<div>
    <div class="row bg-secondary text-white sub_banner">
        <div class="col-12" align="center">
            <strong>REQUISITOS ADICIONALES</strong>
        </div>
    </div>
    <br />
    <div id="cargarRequisitosAdicionalesValida" class="disabledClick">
        <input type="hidden" id="IdManifiestoProveedor" name="IdManifiestoProveedor" value="@Model.oManifiestosProveedores.IdManifiestoProveedor" />
        <input type="hidden" id="IdRequisicion" name="IdRequisicion" value="@Model.oRequisicones.IdRequisicion" />
        <input type="hidden" id="IdProveedorRqInvitacion" name="IdProveedorRqInvitacion" value="@Model.oManifiestosProveedores.IdProveedorRqInvitacion" />
        <div class="row ">
            <div class="col-sm-4">
                <div class="form-group">
                    <label>*Descripción de infraestructura:</label>
                    @Html.TextArea("Infraestructura", Model.oManifiestosProveedores.Infraestructura, new { @id = "Infraestructura", @class = "form-control ", @Required = "" })
                </div>
            </div>
            <div class="col-sm-4">
                <div class="form-group">
                    <label>*Experiencia adquirida en el ramo(años)</label>
                    @Html.TextBox("AnnioExperiencia", Model.oManifiestosProveedores.AnnioExperiencia == 0 ? 1 : Model.oManifiestosProveedores.AnnioExperiencia, new { @type = "number", @id = "AnnioExperiencia number Required", @class = "form-control ", @Required = "", @min = 1 })
                </div>
            </div>
            <div class="col-sm-4">
                <div class="form-group">
                    <label>*Número de empleados</label>
                    @Html.TextBox("NumeroEmpleados", Model.oManifiestosProveedores.NumeroEmpleados == 0 ? 1 : Model.oManifiestosProveedores.NumeroEmpleados, new { @type = "number", @class = "form-control number Required", @Required = "", @id = "NumeroEmpleados", @min = 1 })
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-sm-4 ml-auto">
                <div class="form-group">
                    <label>*Domicilio para oir o recibir notificaciones</label>
                    @Html.TextArea("Domicilio", Model.oManifiestosProveedores.Domicilio, new { @id = "Domicilio", @class = "form-control ", @Required = "" })
                </div>

            </div>
            <div class="col-sm-4">
                <div class="form-group">
                    <label>Aplica capital contable</label>

                    <div class="input-group">


                        <div class="input-group-prepend">
                            <div class="input-group-text">
                                <div class="custom-control custom-checkbox">
                                    <input type="checkbox" aria-label="Checkbox for following text input" class="custom-control-input" name="AplicaCapitalContable" value="" id="AplicaCapitalContable" @(Model.oManifiestosProveedores.AplicaCapitalContable == 1 ? "checked" : "") onclick="activarAplicaCapitalContable()">
                                    <label class="custom-control-label" for="AplicaCapitalContable"></label>
                                </div>
                            </div>
                        </div>
                        <input type="text" name="number" value="@String.Format("{0:N2}",Model.oManifiestosProveedores.CapitalContable > 0 ? Model.oManifiestosProveedores.CapitalContable : 0)" class = "form-control "/>
                        
                    </div>
                </div>
            </div>
            <div class="col-sm-4">
                <div class="form-group">
                    <label>Ingreso último año:</label>
                    <input type="text" name="number" value="@String.Format("{0:N2}",Model.oManifiestosProveedores.IngresosUltimoAnnio > 0 ? Model.oManifiestosProveedores.IngresosUltimoAnnio : 0)" class = "form-control "/>
                </div>
            </div>
        </div>
    </div>

    <br />
    <div class="row bg-secondary text-white sub_banner">
        <div class="col-12" align="center">
            <strong>PRINCIPALES CLIENTES DE LOS ULTIMOS DOS EJERCICIOS</strong>
        </div>
