                    <!-- Modal Header -->
                    <div class="modal-header">
                        <h4 class="modal-title">Nota Especial</h4>
                        <button type="button" class="close" data-dismiss="modal">&times;</button>
                    </div>

                    <!-- Modal body -->
                    <div class="modal-body">
                        <div class="container">

                            <div class="row">
                                <div class="col-sm-12">
                                    <div class="form-group">
                                        <textarea id="NotaEspecial" rows="5" class="form-control" disabled>@Model.condicionesDeEntrega.NotaEspecial</textarea>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- Modal footer -->
