@model iGob.Entidades.beDeterminacionPrecios
<!-- Modal Header -->
<div class="modal-header">
    @if (Model.IdDeterminaPrecioBienServicio == 0)
    {
    <h4 class="modal-title" style="text-align:center;">Alta investigación precio</h4>
    }
    else
    {
    <h4 class="modal-title" style="text-align:center;">Actualizar investigación precio</h4>
    }
    
</div>

<!-- Modal body -->
<div class="modal-body">
    @using (Html.BeginForm(null, null, FormMethod.Post, new { @Class = "data-form", @id = "InvestigacionPrecios" }))
    {
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(true)
        <input type="hidden" name="IdBienServicio" id="IdBienServicio" value="@Model.IdBienServicio">
        <input type="hidden" name="IdDeterminaPrecioBienServicio" id="IdDeterminaPrecioBienServicio" value="@Model.IdDeterminaPrecioBienServicio">
        <input type="hidden" name="IdNivelConfianza" id="IdNivelConfianza" value="@ViewBag.IdNivelConfianza">
        <div class="row form-group">
            <div class="col-md-2 text-right">Producto o servicio:</div>
            <div class="col-md-10 text-left"><input type="text" name="Producto" id="Producto" class="form-control" autocomplete="off" required></div>
        </div>
        <div class="row form-group">
            <div class="col-md-2 text-right">Características:</div>
            <div class="col-md-10 text-left"><textarea id="Caracteristica" class="form-control" cols="5" rows="5" style="resize:none" onkeypress="return false;" readonly></textarea></div>
        </div>


        <div class="row">
            <div class="col-sm-4">
                <div class="form-group">
                    <label>Número de Unidades Economicas(N)</label>
                    <input type="number" id="Poblacion" name="Poblacion" value="@Model.Poblacion" class="form-control " min="1" step="0.01" required />

                </div>
            </div>
            <div class="col-sm-4">
                <div class="form-group">
                    <label>Nivel Confianza</label>
                    @Html.DropDownList("NivelConfianza", ViewBag.NivelConfianza as SelectList, "Seleccione Nivel de confianza", new { @class = "form-control", @required = "", @id = "NivelConfianza" })

                </div>
            </div>

            <div class="col-sm-4">
                <div class="form-group">
                    <label>Margen de error(e)</label>
                    <input type="number" id="MargenError" name="MargenError" value="@Model.MargenError" class="form-control " max="1" min="0.0001" step="0.0001" required />

                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-sm-4">
                <div class="form-group">
                    <label>Varianza(σ)</label>
                    <input type="number" id="Varianza" name="Varianza" value="@Model.Varianza" class="form-control " max="1" min="0.0001" step="0.0001" required />

                </div>
            </div>
            <div class="col-sm-4">
                <div class="form-group">
                    <label>Muestra(n)</label>
                    <input type="number" readonly id="Muestra" name="Muestra" value="@Model.Muestra" class="form-control " required />

                </div>
            </div>
            <div class="col-sm-4">
                <div class="form-group">
                    <label>Muestra redondeada(n)</label>
                    <input type="number" readonly id="MuestraRedondeada" name="MuestraRedondeada" value="@Model.MuestraRedondeada" class="form-control " required />

                </div>
            </div>
        </div>
    }
</div>

<!-- Modal footer -->
<div class="modal-footer">
    <button type="button" class="btn btn-secondary" onclick="calcular()">Calcular</button>
    @if (Model.Mediana == 0)
    {
        if (Model.IdDeterminaPrecioBienServicio == 0)
        {
        <button type="button" class="btn btn-secondary" onclick="saveInvestigacionPrecio()" id="btnGuardar" disabled>Guardar</button>
        }
        else
        {
        <button type="button" class="btn btn-secondary" onclick="saveInvestigacionPrecio()" id="btnActualizar" disabled>Actualizar</button>
        }
    }
    <button type="button" class="btn btn-secondary" data-dismiss="modal">CERRAR</button>
</div>

