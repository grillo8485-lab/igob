@model IEnumerable<iGob.Entidades.beTiposAdjudicacion>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<br />
<button class="btn btn-secondary new-TA">Nuevo Tipo de Adjudicación</button>
<br /><br />
<table class="table table-striped table-hover" id="tableTA">
    <thead align="center">
        <tr>
            <th>Acciones</th>
            <th>Tipo de adjudicación</th>
            <th>@Html.DisplayNameFor(model => model.Abreviatura)</th>
            <th>Monto Mínimo</th>
            <th>Monto Máximo</th>
        </tr>
    </thead>
    <tbody align="center">
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    <div class="form-group" style="min-width:100px;">
                        <a title="Eliminar registro" id="@item.IdTipoAdjudicacion" data-title="@item.TipoAdjudicacion" class="btn btn-secondary btn-circle delete-TA"><span class="icon-garbage-2"></span></a>
                        <a title="Editar registro" id="@item.IdTipoAdjudicacion" data-title="@item.TipoAdjudicacion" data-MMin="@item.MontoMinimo" data-MMax="@item.MontoMaximo" data-abreviatura="@item.Abreviatura" class="btn btn-secondary btn-circle edit-TA">
                            <span class="icon-edit"></span>
                        </a>
                    </div>
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.TipoAdjudicacion)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Abreviatura)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.MontoMinimo)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.MontoMaximo)
                </td>
            </tr>
        }
    </tbody>


</table>
@{
    Html.RenderPartial("EditDeleteModals");
}

@section scripts{
    <script src="~/Scripts/Catalogos/AccionesTA.js"></script>
}