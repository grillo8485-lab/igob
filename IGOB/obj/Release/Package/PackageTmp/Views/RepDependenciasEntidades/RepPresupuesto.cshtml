@{ iGob.Entidades.beRptAppEjecutivosLicitaciones obeRepPre = ViewBag.obeRep;}

<span style="text-align:center;font-weight:bold;">
    PRESUPUESTO DE ADQUISICIONES<br />
    @obeRepPre.Dependencia
</span>

<div id="tabla_datos_Pre" style="width:100%;overflow:auto;">
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Presupuesto de la dependencia</th>
                <th>Presupuesto ejercido</th>
                <th>Presupuesto por ejercer</th>
                <th>Economias</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>@obeRepPre.PresupuestoDependencia.ToString("C2")</td>
                <td>@obeRepPre.PresupuestoEjercido.ToString("C2")</td>
                <td>@obeRepPre.PresupuestoxEjercer.ToString("C2")</td>
                <td>@obeRepPre.MontoTotalEconomia.ToString("C2")</td>
            </tr>
        </tbody>
    </table>
</div>


<script type="text/javascript">
    google.charts.load("current", { packages: ["corechart"] });
    google.charts.setOnLoadCallback(drawChart);


    function drawChart() {
        var dataTable = new google.visualization.DataTable();
        dataTable.addColumn('string', 'Descripcion');
        dataTable.addColumn('number', 'Cantidad');
        // A column for custom tooltip content
        dataTable.addColumn({ type: 'string', role: 'tooltip' });
        dataTable.addRows([
            ['Presupuesto Ejercido: @obeRepPre.PresupuestoEjercido.ToString("C2")', @obeRepPre.PresupuestoEjercido, 'Presupuesto Ejercido: @obeRepPre.PresupuestoEjercido.ToString("C2")'],
            ['Presupuesto pendiente por ejercer: @obeRepPre.PresupuestoxEjercer.ToString("C2")', @obeRepPre.PresupuestoxEjercer, 'Presupuesto pendiente por ejercer:  @obeRepPre.PresupuestoxEjercer.ToString("C2")'],
            ['Economias: @obeRepPre.MontoTotalEconomia.ToString("C2")', @obeRepPre.MontoTotalEconomia, 'Economias: @obeRepPre.MontoTotalEconomia.ToString("C2")']
            
        ]);

        var formatter = new google.visualization.NumberFormat({
            prefix: '$'
        });
        formatter.format(dataTable, 1);

        var options = {
            legend: { position: 'none' },
            is3D: true,
            pieSliceText: 'value',
            sliceVisibilityThreshold: 0,
            colors: ['#f50057', '#6a1b9a', '#ffa000'],
            chartArea: { 'width': '100%', 'height': '80%' },
        };

        var chart = new google.visualization.PieChart(document.getElementById('piechart_3d_Pre'));
        chart.draw(dataTable, options);
    }

</script>

<div id="div_grafica_Pre">
    <br />
    <span style="text-align:center;font-weight:bold;">
        PRESUPUESTO DE ADQUISICIONES<br />
        @obeRepPre.Dependencia
    </span>
    <div id="piechart_3d_Pre" style="width:100%;height:400px;"></div>
    <span>
        <b>Presupuesto de la dependencia: @obeRepPre.PresupuestoDependencia.ToString("C2")</b><br />
        <b style="color:#f50057">Presupuesto Ejercido: @obeRepPre.PresupuestoEjercido.ToString("C2")</b><br />
        <b style="color:#6a1b9a">Presupuesto pendiente por ejercer: @obeRepPre.PresupuestoxEjercer.ToString("C2")</b><br />
        <b style="color:#ffa000">Economias: @obeRepPre.MontoTotalEconomia.ToString("C2")</b><br />
    </span>
</div>

<script>

    function printDataPre() {
        var divToPrint = document.getElementById("tabla_datos_Pre");
        var divGrafica = document.getElementById("div_grafica_Pre");
        var htmlToPrint = '' +
            '<style type="text/css">' +
            'table { border-collapse:collapse;}'+
            'table th, table td {border:1px solid #000; padding:0.5em;}' +
            '</style>';
        var encabezado = '<center><b> PRESUPUESTO DE ADQUISICIONES</b><br><b>@obeRepPre.Dependencia</b><br></center>';
        newWin = window.open("");
        newWin.document.write(htmlToPrint + encabezado + divToPrint.outerHTML + divGrafica.outerHTML);
        newWin.print();
        newWin.close();
    }
</script>
