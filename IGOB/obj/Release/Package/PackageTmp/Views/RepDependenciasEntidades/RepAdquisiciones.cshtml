@{ iGob.Entidades.beRptAppEjecutivosLicitaciones obeRepAdq = ViewBag.obeRep;}

<div id="tabla_datos_Adq" style="width:100%;overflow:auto;">
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Total adjudicado</th>
                <th>Adjudicaciones directas</th>
                <th>Restringidas</th>
                <th>Licitaciones abiertas</th>
                <th>Año</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>@obeRepAdq.MontoAdjudicadoTotal.ToString("C2")</td>
                <td>@obeRepAdq.MontoTotalDirecta.ToString("C2")</td>
                <td>@obeRepAdq.MontoTotalRestringida.ToString("C2")</td>
                <td>@obeRepAdq.MontoTotalLicitaAbierta.ToString("C2")</td>
                <td>@obeRepAdq.Ejercicio</td>
            </tr>
        </tbody>
    </table>
</div>


<script type="text/javascript">
    google.charts.load("current", { packages: ["corechart"] });
    google.charts.setOnLoadCallback(drawChart);


    function drawChart() {
        var dataTable = new google.visualization.DataTable();
        dataTable.addColumn('string', 'Descripcion');
        dataTable.addColumn('number', 'Cantidad');
        // A column for custom tooltip content
        dataTable.addColumn({ type: 'string', role: 'tooltip' });
        dataTable.addRows([
            ['Adjudicaciones Directas: @obeRepAdq.MontoTotalDirecta.ToString("C2")', @obeRepAdq.MontoTotalDirecta, 'Presupuesto Ejercido: @obeRepAdq.MontoTotalDirecta.ToString("C2")'],
            ['Restringidas: @obeRepAdq.MontoTotalRestringida.ToString("C2")', @obeRepAdq.MontoTotalRestringida, 'Economias: @obeRepAdq.MontoTotalRestringida.ToString("C2")'],
            ['Licitaciones Abiertas: @obeRepAdq.MontoTotalLicitaAbierta.ToString("C2")', @obeRepAdq.MontoTotalLicitaAbierta, 'Presupuesto pendiente por ejercer:  @obeRepAdq.MontoTotalLicitaAbierta.ToString("C2")']
        ]);

        var formatter = new google.visualization.NumberFormat({
            prefix: '$'
        });
        formatter.format(dataTable, 1);

        var options = {
            legend: { position: 'none' },
            is3D: true,
            pieSliceText: 'value',
            sliceVisibilityThreshold: 0,
            colors: ['#64dd17', '#4db6ac', '#00ff21'],
            chartArea: { 'width': '100%', 'height': '80%' },
        };

        var chart = new google.visualization.PieChart(document.getElementById('piechart_3d_Adq'));
        chart.draw(dataTable, options);
    }

</script>

<div id="div_grafica_Adq">
    <br />
    <span style="text-align:center;font-weight:bold;">
        Gobierno del Estado de @obeRepAdq.Estado<br />
        Adquisiciones @obeRepAdq.Ejercicio<br />
    </span>
    <div id="piechart_3d_Adq" style="width:100%;height:400px;"></div>
    <span>
        <b>Total adjudicado: @obeRepAdq.MontoAdjudicadoTotal.ToString("C2")</b><br />
        <b style="color:#64dd17">Adjudicaciones directas: @obeRepAdq.MontoTotalDirecta.ToString("C2")</b><br />
        <b style="color:#4db6ac">Restringidas: @obeRepAdq.MontoTotalRestringida.ToString("C2")</b><br />
        <b style="color:#00ff21">Licitaciones abiertas: @obeRepAdq.MontoTotalLicitaAbierta.ToString("C2")</b>
    </span>
</div>

<script>

    function printDataAdq() {
        var divToPrint = document.getElementById("tabla_datos_Adq");
        var divGrafica = document.getElementById("div_grafica_Adq");
        var htmlToPrint = '' +
            '<style type="text/css">' +
            'table { border-collapse:collapse;}'+
            'table th, table td {border:1px solid #000; padding:0.5em;}' +
            '</style>';
        var encabezado = '<center><b>ADQUISICIONES</b><br><b>@obeRepAdq.Dependencia</b><br></center>';
        newWin = window.open("");
        newWin.document.write(htmlToPrint + encabezado + divToPrint.outerHTML + divGrafica.outerHTML);
        newWin.print();
        newWin.close();
    }
</script>
