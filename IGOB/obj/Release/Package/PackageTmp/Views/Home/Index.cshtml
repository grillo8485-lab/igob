<style>
    /* Ensure that the demo table scrolls */

    .hide {
        display: none;
    }

    span.arrow {
        margin-left: 6px;
        height: 26px;
        background: url('http://i45.tinypic.com/f9ifz6.png') no-repeat left center;
    }

    label.error {
        height: 17px;
        border-top: 1px solid #99182c;
        border-right: 1px solid #99182c;
        border-bottom: 1px solid #99182c;
        margin-left: 0;
        padding: 1px 5px 0px 5px;
        font-size: small;
    }
</style>
<div class="container-fluid hidden-phone" style="width:100%;padding-right:0;">
    <div class="row" style="position:fixed;width:100%;z-index:9;">
        <div class="col barra-green">
        </div>
    </div>
    <div class="row">
        <div class="col-9"></div>
        <div class="col-md-2 col-sm-4 infoConoce">
            <label>¿Todavía no usas i Gob?</label><br>
            <a href="../files/login/Brochure.pdf" draggable="false" target="_blank">Da click aquí para conocer más.</a>
        </div>
    </div>
    <div class="row justify-content-center">
        <div class="col-md-4 col-sm-12 col-logo">
            <img class="img-fluid" draggable="false" src="~/Img/login/iGob_logotipo.png" width="100%" />
        </div>
    </div>
    <div class="row justify-content-center">
        <div class="col-md-4 col-sm-12">
            <div class="panel-heading">
                <h1 class="panel-title-login userSelectnone">Ingrese sus datos</h1>
            </div>
            <div class="panel-body">
                @using (Html.BeginForm("Login", "Home", FormMethod.Post, new { @id = "FormAcceso" }))
                {
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary()
                    if (ViewBag.Error == null)
                    {
                        <fieldset>
                            <input type="hidden" name="attemptResponseCode" id="attemptResponseCode" value="" />
                            <input type="hidden" name="authnAttemptId" id="authnAttemptId" value="" />
                            <div style="margin-bottom: 20px" class="input-group">
                                <div class="input-group-prepend">
                                    <div class="input-group-text"><span class="icon-user"></span></div>
                                </div>
                                @Html.TextBox("Usuario", null, new { @class = "form-control", @type = "email", @Required = "True", @Autofocus = "True", @Id = "Usuario", @Placeholder = "Usuario", @Tabindex = "1", @style = "width:70%;" })

                            </div>
                            <div style="margin-bottom: 20px" class="input-group">
                                <div class="input-group-prepend">
                                    <div class="input-group-text"><span class="icon-locked-4"></span></div>
                                </div>
                                @Html.TextBox("Password", null, new { @class = "form-control", @type = "password", @Required = "True", @Autofocus = "True", @Placeholder = "Contraseña", @Tabindex = "2", @id = "Password", @style = "width:70%;" })
                            </div>
                            <div id="container__login">
                                <div class="custom-control custom-checkbox">
                                    <input type="checkbox" class="checkbox-G-login custom-control-input" id="remember" name="remember" value="Remember Me" tabindex="4">
                                    <label class="custom-control-label" style="display: inline;font-weight: 700;text-transform: capitalize;font-size: 18px;user-select:none" for="remember">Recordarme</label>
                                    <button type="submit" class="btn btn-ChangeColor" tabindex="5" id="submitupdate"><strong>ENTRAR</strong></button>

                                </div>
                            </div>
                            <div style="margin-bottom: 6px" class="input-group" id="ErrorMSG">



                            </div>

                            <div id="container__password">
                                ¿Olvidó su contraseña?
                                <a href="/RecuperacionContrasenia/" draggable="false" style="color: #fff!important">
                                    ¡Recupérela aquí!
                                </a>
                            </div>
                        </fieldset>
                    }
                    else
                    {
                        <div id="login-alert" class="alert alert-danger col-sm-12"><h6><span class='fa fa-exclamation-triangle fa-3x'></span><strong>@ViewBag.Error</strong></h6></div>
                    }
                }
            </div>
                </div>
    </div>
    <br />
    <br />


    <footer class="footer">
        <img src="~/Img/login/flechas_bottom.png" draggable="false" width="100%" />
    </footer>
</div>
@section scripts{
<script src="~/Scripts/acceso.js"></script>
    <script src='http://ajax.aspnetcdn.com/ajax/jquery.validate/1.11.0/jquery.validate.min.js'></script>
}