<!-- Modal Edit - New -->
<div class="modal fade" id="CapModal" role="dialog">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header changeColorModal">
                <h4 class="modal-title">Editar capítulo</h4>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            @using (Html.BeginForm(null, null, FormMethod.Post, new { @Id = "form-Cap" }))
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true)
                <div class="modal-body">
                    <div class="row col-12">
                        <div class="col-2">
                            <label> Clave: </label>
                            <input type="number" required name="ClaveCapitulo" id="ClaveCapitulo" class="form-control textDerecha" />
                        </div>
                        <div class="col-10">
                            <label> Capítulo: </label> 
                            <input type="text" required name="Capitulo" id="Capitulo" class="form-control" />

                        </div>
                    </div>
                    <input type="hidden" name="IdCapitulo" id="IdCapitulo" value="0" />
                    <input type="hidden" name="Activo" value="true" />
                </div>
                <div class="modal-footer">
                    <input type="button" class="btn btn-secondary" data-dismiss="modal" value="Cerrar" />
                    <input type="submit" value="Editar" class="btn btn-secondary" />
                </div>
            }
        </div>
    </div>
</div>
<!-- End Modal Edit - New -->
