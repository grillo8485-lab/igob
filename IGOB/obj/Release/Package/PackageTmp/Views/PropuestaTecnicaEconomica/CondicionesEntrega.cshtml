@model IGOB.Models.Requisicion

<div id="div_condiciones_entrega" class="container-fluid tab-pane fade">

    <div class="row bg-secondary text-white sub_banner">
        <div class="col-12" align="center">
            <strong>VALIDAR CONDICIONES DE ENTREGA</strong>
        </div>
    </div>
    <br />
    <div id="cargarLoadCondicionesDeEntrega">
        @using (Html.BeginForm(null, null, FormMethod.Post, new { @Class = "data-form", @id = "div_condiciones_entregaForm" }))
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary()
            <input type="hidden" id="IdRequisicionCondicionEntrega" value="@Model.condicionesDeEntrega.IdRequisicionCondicionEntrega" />
            <input type="hidden" id="IdRequisicion" value="@Model.oRequisicones.IdRequisicion" />
            <div class="row  disabledClick">
                <div class="col-sm-4">
                    <div class="form-group">
                        <label>Plazo de entrega</label>
                        @Html.DropDownList("IdPlazoEntegra", ViewBag.lstPlazoEntrega as SelectList, "Seleccione Plazo Entrega", new { @class = "form-control ", @Required = "", @id = "IdPlazoEntegra" })
                    </div>
                </div>
                <div class="col-sm-4">
                    <div class="form-group">
                        <label>Cantidad</label>
                        <input type="number" class="form-control" value="@Model.condicionesDeEntrega.PlazoEntregaCantidad" id="PlazoEntregaCantidad" min="0">
                    </div>
                </div>
                <div class="col-sm-4">
                    <div class="form-group">
                        <label>Unidad</label>
                        @Html.DropDownList("IdPlazoTiempo", ViewBag.lstPlazoTiempo as SelectList, "Seleccione Unidad", new { @class = "form-control ", @Required = "", @id = "IdPlazoTiempo" })
                    </div>
                </div>
            </div>

            <div class="row disabledClick">
                <div class="col-sm-4">
                    <div class="form-group">
                        <label>Día</label>
                        @Html.DropDownList("IdTipoDia", ViewBag.lstTipoDia as SelectList, "Seleccione Unidad", new { @class = "form-control ", @Required = "", @id = "IdTipoDia" })
                    </div>
                </div>
                <div class="col-sm-4">
                    <div class="form-group">
                        <label>Forma de entrega</label>
                        @Html.DropDownList("IdTipoEntrega", ViewBag.lstTiposEntrega as SelectList, "Seleccione forma de entrega", new { @class = "form-control ", @Required = "", @id = "IdTipoEntrega" })
                    </div>
                </div>
                <div class="col-sm-4">
                    <div class="form-group">
                        <label>Hasta:</label>
                        <div class='input-group date' id='datetimepicker4'>
                            <input type='text' class="form-control" value="@String.Format("{0:yyyy-MM-dd}", Model.condicionesDeEntrega.FechaLimite)" name="FechaLimite" id="FechaLimite" autocomplete="off" readonly />
                            <span class="input-group-addon">
                                <span class="glyphicon glyphicon-time"></span>
                            </span>
                        </div>
                    </div>
                </div>
            </div>
            <div id="idNuevaCondicionDePago">
                <button type="button" class="btn btn-secondary btn-circle " data-toggle="modal" data-target="#modal_condcionesDePago_NotaEspecial">
                    <span class="icon-add-3"></span>
                    NOTA ESPECIAL
                </button>

            </div>
            <br />

            <div class="modal fade" id="modal_condcionesDePago_NotaEspecial">
                <div class="modal-dialog modal-lg">
                    <div class="modal-content">

                        <!-- Modal Header -->
                        <div class="modal-header">
                            <h4 class="modal-title">Nota Especial</h4>
                            <button type="button" class="close" data-dismiss="modal">&times;</button>
                        </div>

                        <!-- Modal body -->
                        <div class="modal-body">
                            <div class="container">

                                <div class="row">
                                    <div class="col-sm-12">
                                        <div class="form-group">
                                            <textarea id="NotaEspecial" rows="5" class="form-control" readonly>@Model.condicionesDeEntrega.NotaEspecial</textarea>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- Modal footer -->
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-dismiss="modal">CERRAR</button>
                        </div>

                    </div>
                </div>
            </div>
        }
    </div>
    <br />
    <table class="table-bordered hover" id="condicionesDeEntragaTable" width="100%">
        <thead>
            <tr>

                <th>Número</th>
                <th>Lote</th>
                <th>Cantidad Entrega</th>
                <th>Lugar Entrega</th>
                <th>Domicilio Entrega</th>
                <th>Mapa</th>
                <th>Horario Inicio Entrega</th>
                <th>Horario Fin Entrega</th>
                <th>Dias Entrega</th>
            </tr>
        </thead>
        <tbody>
            @{var i = 1;}
            @foreach (var item in Model.lstRequisicionCondicionesEntregaDetalleConsulta)
            {
                <tr>

                    <td>@item.NumeroEntrega</td>
                    <td>@item.NoLote</td>
                    <td align="right">@item.CantidadEntregaDetalle</td>
                    <td>@item.Lugar</td>
                    <td>@item.DomicilioEntrega</td>

                    <td style="width:200px;height:200px;">
                        <div id="map-@i" class="maps disabledClick" style="width:150px;height:150px">
                        </div>
                        <input type="hidden" class="inpt" value="@item.LocalizacionGoogle" id="hidden-@i" />
                    </td>
                    <td>@item.HorarioInicio</td>
                    <td>@item.HorarioFinal</td>
                    <td>
                        @if (item.Lunes == 1)
                        {
                            <button type="button" class="btn btn-secondary btn-sm"><span class="badge badge-light">Lunes</span></button>
                        }
                        @if (item.Martes == 1)
                        {
                            <button type="button" class="btn btn-secondary btn-sm"><span class="badge badge-light">Martes</span></button>
                        }
                        @if (item.Miercoles == 1)
                        {
                            <button type="button" class="btn btn-secondary btn-sm"><span class="badge badge-light">Miercoles</span></button>
                        }
                        @if (item.Jueves == 1)
                        {
                            <button type="button" class="btn btn-secondary btn-sm"><span class="badge badge-light">Jueves</span></button>
                        }
                        @if (item.Viernes == 1)
                        {
                            <button type="button" class="btn btn-secondary btn-sm"><span class="badge badge-light">Viernes</span></button>
                        }
                        @if (item.Sabado == 1)
                        {
                            <button type="button" class="btn btn-secondary btn-sm"><span class="badge badge-light">Sabado</span></button>
                        }
                        @if (item.Domingo == 1)
                        {
                            <button type="button" class="btn btn-secondary btn-sm"><span class="badge badge-light">Domingo</span></button>
                        }


                    </td>
                </tr>
                { i++; }
            }
        </tbody>
    </table>
    <br />
    <div id="CargaCondicionesEntregaPanel1">
        <div class="row form-group @Model.visibleTecnicaSolicitante @Model.activarTecnicaSolicitante">
            <div class="col-md-2 text-right">Cumple con lo ofertado (condiciones de entrega):</div>
            <div class="col-md-2 text-left input-group">
                <div class="custom-control custom-checkbox">
                    <input type="radio" class="custom-control-input" name="CondicionEntregaDependenciaCumple" value="1" id="CondicionEntregaDependenciaCumple1" @(Model.oProveedoresRequisicionesInvitacion.CondicionEntregaDependenciaCumple ? "checked" : "") onclick="validaDependenciaCumple('CondicionEntregaDependenciaCumple','CondicionEntregaFundamento')">Si
                    <label class="custom-control-label" for="CondicionEntregaDependenciaCumple1"></label>

                </div>
                <div class="custom-control custom-checkbox">
                    <input type="radio" class="custom-control-input" name="CondicionEntregaDependenciaCumple" value="0" id="CondicionEntregaDependenciaCumple2" @(!Model.oProveedoresRequisicionesInvitacion.CondicionEntregaDependenciaCumple ? "checked" : "") onclick="validaDependenciaCumple('CondicionEntregaDependenciaCumple','CondicionEntregaFundamento')">No
                    <label class="custom-control-label" for="CondicionEntregaDependenciaCumple2"></label>
                </div>
            </div>
            <div class="col-md-2 text-right">Observaciones y fundamentación legal:</div>
            <div class="col-md-6 text-left">
                <textarea id="CondicionEntregaFundamento" name="CondicionEntregaFundamento" rows="3" cols="33" class="form-control" @(Model.oProveedoresRequisicionesInvitacion.CondicionEntregaDependenciaCumple ? "disabled" : "") >@Model.oProveedoresRequisicionesInvitacion.CondicionEntregaFundamento</textarea>
            </div>
        </div>
        <div class="row form-group @Model.visibleTecnicaRevisor  @Model.activarTecnicaRevisor">
            <div class="col-md-2 text-right">Rechazar:</div>
            <div class="col-md-2 text-left  input-group">
                <div class="custom-control custom-checkbox">
                    <input type="radio" class="custom-control-input" name="CondicionEntregaAdquisicionCumple" value="1" id="CondicionEntregaAdquisicionCumple1" @(Model.oProveedoresRequisicionesInvitacion.CondicionEntregaAdquisicionCumple ? "checked" : "") onclick="validaCumpleRevisor('CondicionEntregaAdquisicionCumple','CondicionEntregaAdqObservacion')">Si
                    <label class="custom-control-label" for="CondicionEntregaAdquisicionCumple1"></label>

                </div>
                <div class="custom-control custom-checkbox">
                    <input type="radio" class="custom-control-input" name="CondicionEntregaAdquisicionCumple" value="0" id="CondicionEntregaAdquisicionCumple2" @(!Model.oProveedoresRequisicionesInvitacion.CondicionEntregaAdquisicionCumple ? "checked" : "") onclick="validaCumpleRevisor('CondicionEntregaAdquisicionCumple','CondicionEntregaAdqObservacion')">No
                    <label class="custom-control-label" for="CondicionEntregaAdquisicionCumple2"></label>
                </div>
            </div>
            <div class="col-md-2 text-right">Observaciones adquisición</div>
            <div class="col-md-6 text-left">
                <textarea id="CondicionEntregaAdqObservacion" name="CondicionEntregaAdqObservacion" rows="3" cols="33" class="form-control" @(!Model.oProveedoresRequisicionesInvitacion.CondicionEntregaAdquisicionCumple ? "disabled" : "") >@Model.oProveedoresRequisicionesInvitacion.CondicionEntregaAdqObservacion</textarea>
            </div>
        </div>
    </div>
</div>
