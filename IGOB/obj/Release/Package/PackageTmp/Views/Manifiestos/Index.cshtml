@model IEnumerable<iGob.Entidades.beManifiestos>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<br />
<input class="btn btn-secondary new-Manifiesto" type="button" value="Nuevo Manifiesto" />
<br /><br />

<table class="table table-striped table-hover" id="tableManifiesto">
    <thead align="justify">
        <tr>
            <th>
                Acciones
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Manifiesto)
            </th>

            <th>
                @Html.DisplayNameFor(model => model.Gobierno)
            </th>
        </tr>
    </thead>

    <tbody>


        @foreach (var item in Model)
        {
            <tr>
                <td>
                    <div class="form-group" style="min-width:100px;">
                        <a title="Eliminar registro" id="@item.IdManifiesto" data-title="@item.Manifiesto" class="btn btn-secondary btn-circle btn-sm delete-Manifiesto"><span class="icon-garbage-2"></span></a>
                        <a title="Editar registro" id="@item.IdManifiesto" data-title="@item.Manifiesto" data-gob="@item.IdGobierno" class="btn btn-secondary btn-circle btn-sm edit-Manifiesto"><span class="icon-edit"></span></a>
                    </div>
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Manifiesto)
                </td>

                <td>
                    @Html.DisplayFor(modelItem => item.Gobierno)
                </td>
            </tr>
        }
    </tbody>
</table>
@{
    Html.RenderPartial("EditDeleteModals");
}

@section scripts{
    <script src="~/Scripts/Catalogos/AccionesManifiesto.js"></script>
}