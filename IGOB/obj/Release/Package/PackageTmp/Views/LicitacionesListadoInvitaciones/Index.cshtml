@model IEnumerable<iGob.Entidades.beListadoLicitacionesInvitacionProveedores>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<table class="table-bordered hover" id="LicitacionesListadoInvitaciones">
    <thead>
        <tr>
            <th> Acciones </th>
            <th> Licitación </th>
            <th> Partidas </th>
            <th> Dependencias </th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
        <tr>
            <td align="center">
                <button title="Abrir licitación" type="button" class="btn btn-secondary btn-circle edit-marca btn-sm" to onclick="location.href='@Url.Action("Index", "AceptarInvitacion",new { IdLicitacion = item.IdLicitacion })'">
                    <span class="glyphicon glyphicon-eye-open"></span>
                </button>
            </td>
            <td>@item.FolioOficial</td>
            <td>@item.Partidas</td>
            <td>@item.Dependencias</td>
        </tr>
        }
    </tbody>
</table>
<div id="modaldiv"></div>
@section scripts{
    <script src="~/Scripts/Catalogos/LicitacionesListadoInvitaciones.js"></script>
    }