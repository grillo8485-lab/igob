<div id="div_condiciones_entrega_pago" class="container-fluid tab-pane fade">
    <div id="condicionEntregaDiv">
        @using (Html.BeginForm(null, null, FormMethod.Post, new { @Class = "data-form", id = "div_condiciones_entrega_pagoForm" }))
        {
            <div class="row">
                <div class="col-sm-3">

                    <div class="form-group">
                        <label>Fecha de entrega</label>
                        <div class='input-group'>
                            <input type='text' class="form-control datetimepicker4" name="FechaEntrega" id="FechaEntrega" autocomplete="off" readonly />
                            <span class="input-group-addon">
                                <span class="glyphicon glyphicon-calendar"></span>
                            </span>
                        </div>
                    </div>
                    
                </div>
                <div class="col-sm-7">
                    <div class="form-group">
                        <label>Lugar de entrega</label>
                        @Html.DropDownList("IdLugarEntrega", ViewBag.lstLugaresEntrega as SelectList, "Seleccione Lugar de Entrega", new { @class = "form-control", @Required = "" })
                    </div>
                </div>
            </div>
            <hr />
            <div class="row">
                <div class="col-sm-3">

                    <div class="form-group">
                        <label>Fecha de pago</label>
                        <div class='input-group'>
                            <input type='text' class="form-control datetimepicker4" name="FechaPago" id="FechaPago" autocomplete="off" readonly />
                            <span class="input-group-addon">
                                <span class="glyphicon glyphicon-calendar"></span>
                            </span>
                        </div>
                    </div>
                    
                </div>
                <div class="col-sm-7">
                    <div class="form-group">
                        <label>Lugar de pago</label>
                        @Html.DropDownList("IdLugarPago", ViewBag.lstLugaresPago as SelectList, "Seleccione Lugar de Pago", new { @class = "form-control", @Required = "" })
                    </div>
                </div>
            </div>

            <div class="row" style="display:none">
                <div class="col-sm-4 offset-sm-8">
                    <div class="form-group">
                        <label>Token</label>
                        <input type="password" class="form-control">
                    </div>
                </div>
            </div>
        }
    </div>
</div>